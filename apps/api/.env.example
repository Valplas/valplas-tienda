# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# Frontend URL
FRONTEND_URL=http://localhost:3000

# CORS - Allowed Origins (comma-separated, supports wildcards)
# Development:
ALLOWED_ORIGINS=http://localhost:3000
# Production (Railway):
# ALLOWED_ORIGINS=https://valplas-tienda-web.vercel.app,https://*.vercel.app,http://localhost:3000
# El wildcard https://*.vercel.app permite todos los preview deployments de Vercel

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Authentication
JWT_SECRET=tu-secret-muy-seguro-minimo-32-caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (Upstash) - Opcional
REDIS_URL=redis://default:[PASSWORD]@[HOST].upstash.io:6379

# Mercado Pago
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_WEBHOOK_SECRET=tu-webhook-secret

# Mercado Pago (Bot de WhatsApp)
MERCADOPAGO_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MERCADOPAGO_NOTIFICATION_URL=https://api.valplas.net/api/orders/webhook/mp

# WhatsApp Bot (Meta Cloud API)
# Configurar en https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxx
WHATSAPP_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=tu-verify-token-secreto
ADMIN_WHATSAPP_NUMBER=+5491100000000

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxx
EMAIL_FROM=Valplas <no-reply@valplas.net>

# Google OAuth
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# Sentry
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
