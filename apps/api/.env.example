# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# Frontend URL
FRONTEND_URL=http://localhost:3000

# CORS - Allowed Origins (comma-separated, supports wildcards)
# Development:
ALLOWED_ORIGINS=http://localhost:3000
# Production (Railway): usá dominios EXPLÍCITOS.
# ALLOWED_ORIGINS=https://valplas.net,https://www.valplas.net,https://valplas-tienda-web.vercel.app
# ⚠️ SEGURIDAD: NO uses un wildcard amplio como https://*.vercel.app junto con cookies de sesión.
# Cualquiera puede desplegar en *.vercel.app y, al reflejarse el origin con credentials:true,
# leer respuestas autenticadas de un usuario logueado. Si necesitás previews, listá su dominio exacto.

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# TLS de la conexión a Postgres (en producción se valida el certificado por defecto).
# Si tu proveedor usa una CA propia, pegá el PEM (con \n) en DATABASE_CA_CERT.
# Solo como último recurso (debilita la seguridad): DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_CA_CERT=
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Loguear cada query SQL (solo debug local; en Railway supera el rate limit de logs)
# DEBUG_SQL=true

# Supabase
SUPABASE_SERVICE_KEY=eyJ...

# Authentication
JWT_SECRET=tu-secret-muy-seguro-minimo-32-caracteres
# Secreto separado para refresh tokens (recomendado). Si se omite, usa JWT_SECRET.
JWT_REFRESH_SECRET=otro-secret-distinto-minimo-32-caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Cookies cross-site: poner true en deploys HTTPS donde frontend y API estan en dominios
# distintos (ej: Vercel + Railway). Fuerza SameSite=None; Secure sin depender de NODE_ENV.
# En local (http://localhost) dejar false.
COOKIE_CROSS_SITE=false

# Redis (Upstash) - Opcional
REDIS_URL=redis://default:[PASSWORD]@[HOST].upstash.io:6379

# Mercado Pago
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_WEBHOOK_SECRET=tu-webhook-secret
# OAuth — solo necesario para el flujo de autorización del dueño de Valplas
MP_CLIENT_ID=tu-client-id-de-la-app-en-mp
MP_CLIENT_SECRET=tu-client-secret-de-la-app-en-mp
# Elegís vos este valor — debe coincidir con el state en la URL de autorización
MP_OAUTH_STATE=un-string-secreto-random

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxx
EMAIL_FROM=Valplas <no-reply@valplas.net>

# Google OAuth
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# Sentry
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Seeds (solo desarrollo/test — los seeds se bloquean en producción)
# Contraseña para los usuarios sembrados. Si se omite, se genera una aleatoria y se loguea.
# Debe tener al menos 12 caracteres.
# SEED_PASSWORD=
# Permite ejecutar seeds con NODE_ENV=production (peligroso). Dejar sin definir en prod.
# ALLOW_PRODUCTION_SEED=false
