{
  "permissions": {
    "allow": ["Bash", "Read", "Write", "WebSearch", "Skill(superpowers:*)"],
    "deny": ["Bash(git push:*)"],
    "ask": ["Read(.env*)", "Read(.git/**)", "Bash(rm -rf:*)"]
  },
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File ./scripts/claude-post-edit-hook.ps1"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["supabase-db", "filesystem", "github"],
  "enableAllProjectMcpServers": true,
  "description": "Claude Code hooks para Valplas - Ejecuta verificaciones automáticas después de editar/crear archivos"
}
