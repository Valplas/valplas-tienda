{
  "name": "valplas-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun --filter @valplas/api dev\" \"bun --filter @valplas/web dev\"",
    "dev:web": "bun --filter @valplas/web dev",
    "dev:api": "bun --filter @valplas/api dev",
    "build": "bun --filter '*' build",
    "build:web": "bun --filter @valplas/web build",
    "build:api": "bun --filter @valplas/api build",
    "test": "bun --filter '*' test",
    "test:watch": "bun --filter '*' test:watch",
    "lint": "bun --filter '*' lint",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "bun --filter '*' typecheck",
    "db:migrate": "bun --filter @valplas/api db:migrate",
    "db:migrate:create": "bun --filter @valplas/api db:migrate:create",
    "db:seed": "bun --filter @valplas/api db:seed",
    "prepare": "husky",
    "check-secrets": "node scripts/check-secrets.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.2",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  }
}
