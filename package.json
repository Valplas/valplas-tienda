{
  "name": "valplas-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun --filter @valplas/api dev\" \"bun --filter @valplas/web dev\"",
    "dev:web": "bun --filter @valplas/web dev",
    "dev:api": "bun --filter @valplas/api dev",
    "build": "bun --filter '*' build",
    "build:web": "bun --filter @valplas/web build",
    "build:api": "bun --filter @valplas/api build",
    "start:api": "bun --filter @valplas/api start",
    "test": "bun --filter '*' test",
    "test:watch": "bun --filter '*' test:watch",
    "lint": "bun --filter '*' lint",
    "lint:staged": "lint-staged",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "bun --filter '*' typecheck",
    "db:migrate": "bun --filter @valplas/api db:migrate",
    "db:migrate:create": "bun --filter @valplas/api db:migrate:create",
    "db:seed": "bun --filter @valplas/api db:seed",
    "db:reset": "bun db:migrate && bun db:seed",
    "prepare": "husky",
    "check-secrets": "node scripts/check-secrets.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.8.4",
    "typescript": "^7.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "qs": "6.15.2",
    "dompurify": "3.4.11",
    "vite": "7.3.5",
    "yaml": "2.9.0",
    "rollup": "4.62.2",
    "flatted": "3.4.2",
    "postcss": "8.5.15",
    "@babel/core": "7.29.7",
    "js-yaml": "4.2.0",
    "uuid": "11.1.1"
  },
  "patchedDependencies": {
    "swagger-jsdoc@6.2.8": "patches/swagger-jsdoc@6.2.8.patch"
  }
}
